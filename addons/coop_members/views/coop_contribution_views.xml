<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_coop_contribution_form" model="ir.ui.view">
        <field name="name">coop.contribution.form</field>
        <field name="model">coop.contribution</field>
        <field name="arch" type="xml">
            <form string="Aporte / Retiro">
                <header>
                    <button name="action_confirm" string="Confirmar"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Anular"
                            type="object"
                            invisible="state not in ('draft', 'confirmed')"/>
                    <button name="action_draft" string="Volver a borrador"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="member_id"/>
                            <field name="name"/>
                            <field name="type"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                            <field name="move_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Observaciones opcionales..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_coop_contribution_tree" model="ir.ui.view">
        <field name="name">coop.contribution.list</field>
        <field name="model">coop.contribution</field>
        <field name="arch" type="xml">
            <list string="Aportes y Retiros"
                  decoration-success="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'">
                <field name="date"/>
                <field name="member_id"/>
                <field name="name"/>
                <field name="type" widget="badge"/>
                <field name="amount"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'draft'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_coop_contribution" model="ir.actions.act_window">
        <field name="name">Aportes y Retiros</field>
        <field name="res_model">coop.contribution</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
