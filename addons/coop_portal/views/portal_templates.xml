<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ LAYOUT ============ -->
    <template id="layout" name="App socios: layout">
        <t t-set="nav_activo" t-value="nav_activo or 'inicio'"/>
        &lt;!DOCTYPE html&gt;
        <html lang="es">
        <head>
            <meta charset="utf-8"/>
            <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1"/>
            <meta name="theme-color" content="#1a7f4e"/>
            <title>coopeapp</title>
            <style>
                :root{--verde:#1a7f4e;--verde-claro:#e6f4ec;--amarillo:#f5a623;--rojo:#d0413b;
                      --tinta:#1d2733;--gris:#6b7785;--fondo:#f4f6f8;--blanco:#fff;--radio:14px}
                *{box-sizing:border-box;margin:0;-webkit-tap-highlight-color:transparent}
                body{font-family:-apple-system,'Segoe UI',Roboto,sans-serif;background:var(--fondo);
                     color:var(--tinta);padding:18px 16px 92px;max-width:480px;margin:0 auto}
                h1{font-size:22px;margin-bottom:4px}
                .sub{color:var(--gris);font-size:15px;margin-bottom:18px}
                .card{background:var(--blanco);border-radius:var(--radio);
                      box-shadow:0 1px 4px rgba(0,0,0,.08);padding:16px;margin-bottom:12px}
                .card h3{font-size:14px;color:var(--gris);font-weight:600;margin-bottom:6px}
                .nro{font-size:32px;font-weight:800}
                .botonazo{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;
                          min-height:60px;border:0;border-radius:var(--radio);background:var(--verde);
                          color:#fff;font-size:18px;font-weight:700;margin:6px 0;text-decoration:none;
                          cursor:pointer}
                .botonazo.sec{background:var(--blanco);color:var(--tinta);border:2px solid #d7dee5}
                .chip{display:inline-block;padding:4px 10px;border-radius:20px;font-size:13px;font-weight:700}
                .chip.ok{background:var(--verde-claro);color:var(--verde)}
                .chip.espera{background:#fdf3e0;color:#a36b00}
                .barra{height:18px;background:#e2e8ee;border-radius:10px;overflow:hidden;margin:8px 0}
                .barra div{height:100%;background:var(--verde);border-radius:10px}
                .fila{display:flex;justify-content:space-between;align-items:center;padding:10px 0;
                      border-bottom:1px solid #eef2f5;font-size:15px;gap:8px}
                .fila:last-child{border:0}
                .opcion{display:flex;align-items:center;gap:12px;width:100%;background:var(--blanco);
                        border:2px solid #d7dee5;border-radius:var(--radio);padding:18px 14px;
                        font-size:17px;font-weight:600;color:var(--tinta);margin-bottom:10px;
                        text-decoration:none;cursor:pointer;text-align:left}
                .paso{font-size:14px;color:var(--gris);font-weight:700;margin-bottom:6px}
                .pregunta{font-size:24px;font-weight:800;margin-bottom:18px}
                .numero-grande{width:100%;font-size:46px;font-weight:800;text-align:center;
                               border:2px solid #d7dee5;border-radius:var(--radio);padding:14px;margin:10px 0}
                .listo{display:flex;flex-direction:column;align-items:center;text-align:center;padding:40px 10px}
                .check{width:110px;height:110px;border-radius:50%;background:var(--verde);color:#fff;
                       font-size:60px;display:flex;align-items:center;justify-content:center;margin-bottom:20px}
                .atras{color:var(--gris);font-size:15px;font-weight:700;text-decoration:none;
                       display:inline-block;padding-bottom:14px}
                .nav{position:fixed;bottom:0;left:0;right:0;background:var(--blanco);
                     border-top:1px solid #e2e8ee;display:flex;padding:6px 4px 12px;max-width:480px;
                     margin:0 auto}
                .nav a{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;
                       font-size:12px;font-weight:600;color:var(--gris);text-decoration:none;padding:6px 0}
                .nav a.viva{color:var(--verde)}
                .nav .ico{font-size:22px;line-height:1}
                label.radio{display:flex;align-items:center;gap:12px;width:100%;background:var(--blanco);
                        border:2px solid #d7dee5;border-radius:var(--radio);padding:16px 14px;
                        font-size:17px;font-weight:600;margin-bottom:10px;cursor:pointer}
                label.radio input{width:22px;height:22px;accent-color:var(--verde)}
            </style>
        </head>
        <body>
            <t t-out="0"/>
            <div class="nav" t-if="nav_rol == 'sindico'">
                <a href="/app/control" t-att-class="'viva' if nav_activo == 'control' else None"><span class="ico">🛡️</span>Control</a>
                <a href="/app/auditoria" t-att-class="'viva' if nav_activo == 'auditoria' else None"><span class="ico">🔎</span>Auditoría</a>
                <a href="/app/asamblea" t-att-class="'viva' if nav_activo == 'asamblea' else None"><span class="ico">🗳️</span>Asamblea</a>
                <a href="/app/certificados" t-att-class="'viva' if nav_activo == 'firmar' else None"><span class="ico">✍️</span>Firmar</a>
            </div>
            <div class="nav" t-elif="nav_rol == 'admin'">
                <a href="/app/admin" t-att-class="'viva' if nav_activo == 'tablero' else None"><span class="ico">📊</span>Tablero</a>
                <a href="/app/admin/ruta" t-att-class="'viva' if nav_activo == 'ruta' else None"><span class="ico">🔴</span>Ruta</a>
                <a href="/app/admin/reportes" t-att-class="'viva' if nav_activo == 'reportes' else None"><span class="ico">📋</span>Reportes</a>
                <a href="/app/asamblea" t-att-class="'viva' if nav_activo == 'asamblea' else None"><span class="ico">🗳️</span>Asamblea</a>
            </div>
            <div class="nav" t-else="">
                <a href="/app" t-att-class="'viva' if nav_activo == 'inicio' else None"><span class="ico">🏠</span>Inicio</a>
                <a href="/app/cargar" t-att-class="'viva' if nav_activo == 'cargar' else None"><span class="ico">✏️</span>Cargar</a>
                <a href="/app/plata" t-att-class="'viva' if nav_activo == 'plata' else None"><span class="ico">💵</span>Mi plata</a>
                <a href="/app/obra" t-att-class="'viva' if nav_activo == 'obra' else None"><span class="ico">🏗️</span>Obra</a>
            </div>
        </body>
        </html>
    </template>

    <!-- ============ AVISOS ============ -->
    <template id="sin_socio" name="App: usuario sin socio">
        <t t-call="coop_portal.layout">
            <div class="listo">
                <div class="check" style="background:#a36b00">!</div>
                <h1>Tu usuario no está vinculado a un socio</h1>
                <p class="sub" style="margin-top:8px">Pedile al administrador que asocie tu usuario al padrón de socios.</p>
            </div>
        </t>
    </template>

    <template id="sin_obra" name="App: socio sin obra">
        <t t-call="coop_portal.layout">
            <div class="listo">
                <div class="check" style="background:#a36b00">🏗️</div>
                <h1>Todavía no estás asignado a una obra</h1>
                <p class="sub" style="margin-top:8px">Cuando el coordinador te sume al plantel, acá vas a ver tu obra.</p>
            </div>
        </t>
    </template>

    <!-- ============ INICIO ============ -->
    <template id="home" name="App: inicio socio">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'inicio'"/>
            <h1>Hola, <t t-esc="member.name.split(' ')[0]"/> 👋</h1>
            <div class="sub" t-if="obras">Obra: <t t-esc="obras[0].name"/></div>
            <div class="sub" t-else="">Sin obra asignada por ahora</div>

            <a class="botonazo" href="/app/cargar">✏️ CARGAR LO QUE HICE</a>

            <div class="card" t-if="asamblea" style="border-left:6px solid #f5a623">
                <h3>🗳️ ASAMBLEA EN CURSO</h3>
                <div style="font-size:16px;font-weight:700;margin-bottom:10px"><t t-esc="asamblea.name"/></div>
                <a class="botonazo" style="min-height:50px;font-size:16px;margin:0" href="/app/asamblea">ENTRAR Y VOTAR</a>
            </div>

            <div class="card" t-if="es_coordinador" style="border-left:6px solid #f5a623">
                <h3>SOS COORDINADOR</h3>
                <a class="fila" href="/app/validar" style="text-decoration:none;color:inherit">
                    <div>👍 Avances para revisar</div>
                    <span t-attf-class="chip {{'espera' if n_validar else 'ok'}}">
                        <t t-esc="n_validar"/> <t t-if="not n_validar">✓</t>
                    </span>
                </a>
                <a class="fila" href="/app/pedidos" style="text-decoration:none;color:inherit;border:0">
                    <div>🧱 Pedidos de materiales</div>
                    <span t-attf-class="chip {{'espera' if n_pedidos else 'ok'}}">
                        <t t-esc="n_pedidos"/> <t t-if="not n_pedidos">✓</t>
                    </span>
                </a>
            </div>

            <div class="card" t-if="avances">
                <h3>TUS ÚLTIMAS CARGAS</h3>
                <div class="fila" t-foreach="avances" t-as="a">
                    <div>
                        <t t-esc="a.fecha.strftime('%d/%m')"/> —
                        <t t-esc="a.foja_item_id.name"/>
                        <b><t t-esc="'%g' % a.cantidad"/> <t t-esc="uom_labels.get(a.uom, a.uom)"/></b>
                    </div>
                    <span t-if="a.state == 'validado'" class="chip ok">✓ Validado</span>
                    <span t-else="" class="chip espera">⏳ Lo revisa el coordinador</span>
                </div>
            </div>
        </t>
    </template>

    <!-- ============ CARGAR PASO 1 ============ -->
    <template id="cargar_paso1" name="App: cargar paso 1">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'cargar'"/>
            <a class="atras" href="/app">← Salir</a>
            <div class="paso">PASO 1 DE 3 · <t t-esc="obra.name"/></div>
            <div class="pregunta">¿En qué trabajaste?</div>
            <t t-if="len(obras) &gt; 1">
                <div class="sub">Otra obra:
                    <t t-foreach="obras" t-as="o">
                        <a t-if="o.id != obra.id" t-attf-href="/app/cargar?obra_id={{o.id}}"
                           style="font-weight:700"><t t-esc="o.name"/> </a>
                    </t>
                </div>
            </t>
            <a class="opcion" t-foreach="items" t-as="i"
               t-attf-href="/app/cargar/cantidad?item_id={{i.id}}">
                <span><t t-esc="i.item"/> · <t t-esc="i.name"/></span>
                <span style="margin-left:auto;color:var(--gris)">
                    <t t-esc="uom_labels.get(i.uom, i.uom)"/>
                </span>
            </a>
            <div class="card" t-if="not items">
                <h3>SIN ÍTEMS</h3>
                <div>La obra todavía no tiene foja de medición cargada. Avisale al coordinador.</div>
            </div>
        </t>
    </template>

    <!-- ============ CARGAR PASO 2 ============ -->
    <template id="cargar_paso2" name="App: cargar paso 2">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'cargar'"/>
            <a class="atras" href="/app/cargar">← Volver</a>
            <div class="paso">PASO 2 DE 3</div>
            <div class="pregunta">¿Cuánto hiciste?</div>
            <div class="sub"><t t-esc="item.name"/></div>
            <form action="/app/cargar/trabajo" method="get">
                <input type="hidden" name="item_id" t-att-value="item.id"/>
                <input class="numero-grande" type="number" name="cantidad" step="any"
                       min="0.01" required="required" inputmode="decimal"
                       t-attf-placeholder="{{uom_labels.get(item.uom, item.uom)}}"/>
                <button class="botonazo" type="submit">Seguir →</button>
            </form>
        </t>
    </template>

    <!-- ============ CARGAR PASO 3 ============ -->
    <template id="cargar_paso3" name="App: cargar paso 3">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'cargar'"/>
            <a class="atras" t-attf-href="/app/cargar/cantidad?item_id={{item.id}}">← Volver</a>
            <div class="paso">PASO 3 DE 3</div>
            <div class="pregunta">¿Cuánto trabajo te llevó?</div>
            <form action="/app/cargar/confirmar" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="item_id" t-att-value="item.id"/>
                <input type="hidden" name="cantidad" t-att-value="cantidad"/>
                <label class="radio" t-foreach="medidas" t-as="m">
                    <input type="radio" name="medida_trabajo" t-att-value="m[0]"
                           t-att-checked="'checked' if m[0] == 'jornal' else None" required="required"/>
                    <span><t t-esc="m[2]"/> <t t-esc="m[1]"/></span>
                </label>
                <div class="paso" style="margin-top:10px">¿CUÁNTOS? (jornales / horas / tareas)</div>
                <input class="numero-grande" type="number" name="cantidad_trabajo" step="any"
                       min="0.1" value="1" required="required" inputmode="decimal"/>
                <button class="botonazo" type="submit">CONFIRMAR ✓</button>
            </form>
        </t>
    </template>

    <!-- ============ CARGAR LISTO ============ -->
    <template id="cargar_listo" name="App: avance cargado">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'cargar'"/>
            <div class="listo">
                <div class="check">✓</div>
                <h1>¡Listo, <t t-esc="member.name.split(' ')[0]"/>!</h1>
                <p class="sub" style="margin-top:8px">
                    Cargaste <b><t t-esc="'%g' % avance.cantidad"/></b> de
                    "<t t-esc="item.name"/>".<br/>
                    Ahora lo revisa el coordinador y suma a tu participación.
                </p>
                <a class="botonazo" href="/app">Volver al inicio</a>
                <a class="atras" t-attf-href="/app/cargar/cantidad?item_id={{item.id}}">Cargar otro</a>
            </div>
        </t>
    </template>

    <!-- ============ MI PLATA ============ -->
    <template id="plata" name="App: mi plata">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'plata'"/>
            <h1>Mi plata</h1>
            <div class="sub">Tus liquidaciones y tu producción</div>

            <div class="card" t-if="payrolls">
                <h3>ÚLTIMA LIQUIDACIÓN</h3>
                <div class="nro">$ <t t-esc="'{:,.0f}'.format(payrolls[0].net_amount).replace(',', '.')"/></div>
                <div class="sub" style="margin:4px 0 0">
                    <t t-esc="payrolls[0].date_from.strftime('%d/%m')"/> al
                    <t t-esc="payrolls[0].date_to.strftime('%d/%m')"/> ·
                    <t t-esc="payroll_state_labels.get(payrolls[0].state, payrolls[0].state)"/>
                </div>
            </div>
            <div class="card" t-if="len(payrolls) &gt; 1">
                <h3>ANTERIORES</h3>
                <div class="fila" t-foreach="payrolls[1:]" t-as="p">
                    <div><t t-esc="p.date_to.strftime('%m/%Y')"/></div>
                    <b>$ <t t-esc="'{:,.0f}'.format(p.net_amount).replace(',', '.')"/></b>
                </div>
            </div>
            <div class="card" t-if="not payrolls">
                <h3>LIQUIDACIONES</h3>
                <div>Todavía no tenés liquidaciones cargadas.</div>
            </div>

            <div class="card" t-if="validados">
                <h3>TU PRODUCCIÓN VALIDADA</h3>
                <div class="fila" t-foreach="validados" t-as="v">
                    <div><t t-esc="v.foja_item_id.name"/></div>
                    <b><t t-esc="'%g' % v.cantidad"/> en <t t-esc="'%g' % v.cantidad_trabajo"/>
                       <t t-esc="medida_labels.get(v.medida_trabajo, v.medida_trabajo)"/></b>
                </div>
            </div>
        </t>
    </template>

    <!-- ============ LA OBRA ============ -->
    <template id="obra" name="App: la obra">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'obra'"/>
            <h1>La obra</h1>
            <div class="sub"><t t-esc="obra.name"/></div>
            <t t-if="len(obras) &gt; 1">
                <div class="sub">Otra obra:
                    <t t-foreach="obras" t-as="o">
                        <a t-if="o.id != obra.id" t-attf-href="/app/obra?obra_id={{o.id}}"
                           style="font-weight:700"><t t-esc="o.name"/> </a>
                    </t>
                </div>
            </t>

            <div class="card">
                <h3>AVANCE TOTAL</h3>
                <div class="nro"><t t-esc="'%.0f' % obra.avance_fisico"/><span style="font-size:16px;color:var(--gris)"> %</span></div>
                <div class="barra"><div t-attf-style="width:{{min(obra.avance_fisico, 100.0)}}%"/></div>
                <div style="color:var(--gris);font-size:13px">Lo mismo que ve el consejo. Sin secretos.</div>
            </div>

            <a class="botonazo" href="/app/pedir">🧱 PEDIR MATERIALES</a>

            <div class="card" t-if="etapa">
                <h3>ETAPA <t t-esc="etapa.numero"/> — <t t-esc="etapa_state_labels.get(etapa.state, etapa.state)"/></h3>
                <div class="fila"><div>Ingreso de la etapa</div>
                    <b>$ <t t-esc="'{:,.0f}'.format(etapa.ingreso).replace(',', '.')"/></b></div>
                <div class="fila"><div>Gastado</div>
                    <b>$ <t t-esc="'{:,.0f}'.format(etapa.total_pagado).replace(',', '.')"/></b></div>
                <div class="fila"><div>Saldo sin planificar</div>
                    <b style="color:var(--verde)">$ <t t-esc="'{:,.0f}'.format(etapa.saldo_sin_planificar).replace(',', '.')"/></b></div>
            </div>
        </t>
    </template>

    <!-- ============ COORDINADOR: VALIDAR AVANCES ============ -->
    <template id="coord_validar" name="App: coordinador valida avances">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'inicio'"/>
            <a class="atras" href="/app">← Volver</a>
            <h1>👍 Avances para revisar</h1>
            <div class="sub">Validá o devolvé al socio. Una por una.</div>

            <div class="card" t-foreach="avances" t-as="a">
                <div style="font-weight:800;font-size:16px"><t t-esc="a.member_id.name"/></div>
                <div style="font-size:14px;color:var(--gris);margin-bottom:10px">
                    <t t-esc="a.foja_item_id.name"/> —
                    <b><t t-esc="'%g' % a.cantidad"/> <t t-esc="uom_labels.get(a.uom, a.uom)"/></b>
                    en <t t-esc="'%g' % a.cantidad_trabajo"/>
                    <t t-esc="medida_labels.get(a.medida_trabajo, a.medida_trabajo)"/>
                    · <t t-esc="a.fecha.strftime('%d/%m')"/>
                    · <t t-esc="a.obra_id.name"/>
                </div>
                <div style="display:flex;gap:10px">
                    <form action="/app/validar/accion" method="post" style="flex:1">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="avance_id" t-att-value="a.id"/>
                        <input type="hidden" name="accion" value="validar"/>
                        <button class="botonazo" style="min-height:52px;font-size:16px;margin:0" type="submit">✓ Está bien</button>
                    </form>
                    <form action="/app/validar/accion" method="post" style="flex:1">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="avance_id" t-att-value="a.id"/>
                        <input type="hidden" name="accion" value="rechazar"/>
                        <button class="botonazo sec" style="min-height:52px;font-size:16px;margin:0" type="submit">✗ Corregir</button>
                    </form>
                </div>
            </div>

            <div class="listo" t-if="not avances">
                <div class="check">✓</div>
                <h1>Todo revisado</h1>
                <p class="sub" style="margin-top:8px">No hay avances esperando. Buen trabajo.</p>
                <a class="botonazo" href="/app">Volver al inicio</a>
            </div>
        </t>
    </template>

    <!-- ============ COORDINADOR: PEDIDOS ============ -->
    <template id="coord_pedidos" name="App: coordinador revisa pedidos">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'inicio'"/>
            <a class="atras" href="/app">← Volver</a>
            <h1>🧱 Pedidos de materiales</h1>
            <div class="sub">Aceptá, corregí o rechazá.</div>

            <div class="card" t-foreach="pedidos" t-as="p">
                <div style="font-weight:800;font-size:16px"><t t-esc="p.member_id.name"/></div>
                <div style="font-size:14px;color:var(--gris);margin-bottom:10px">
                    <b><t t-esc="p.name"/></b> · <t t-esc="p.obra_id.name"/>
                    <t t-if="p.nota"> · <t t-esc="p.nota"/></t>
                </div>
                <div style="display:flex;gap:10px;margin-bottom:8px">
                    <form action="/app/pedidos/accion" method="post" style="flex:1">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="pedido_id" t-att-value="p.id"/>
                        <input type="hidden" name="accion" value="aceptar"/>
                        <button class="botonazo" style="min-height:48px;font-size:15px;margin:0" type="submit">✓ Aceptar</button>
                    </form>
                    <form action="/app/pedidos/accion" method="post" style="flex:1">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="pedido_id" t-att-value="p.id"/>
                        <input type="hidden" name="accion" value="rechazar"/>
                        <button class="botonazo sec" style="min-height:48px;font-size:15px;margin:0" type="submit">✗ Rechazar</button>
                    </form>
                </div>
                <form action="/app/pedidos/accion" method="post" style="display:flex;gap:8px;align-items:center">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="pedido_id" t-att-value="p.id"/>
                    <input type="hidden" name="accion" value="corregir"/>
                    <input type="number" name="cantidad" step="any" min="0.01"
                           t-att-placeholder="'Corregir cant. (pidió %g)' % p.cantidad"
                           style="flex:1;padding:10px;border:2px solid #d7dee5;border-radius:10px;font-size:15px"/>
                    <button class="botonazo sec" style="min-height:42px;font-size:14px;margin:0;width:auto;padding:0 14px" type="submit">✏️ y aceptar</button>
                </form>
            </div>

            <div class="listo" t-if="not pedidos">
                <div class="check">✓</div>
                <h1>Sin pedidos pendientes</h1>
                <a class="botonazo" href="/app">Volver al inicio</a>
            </div>
        </t>
    </template>

    <!-- ============ SOCIO: PEDIR MATERIALES (paso 1) ============ -->
    <template id="pedir_paso1" name="App: pedir material paso 1">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'obra'"/>
            <a class="atras" href="/app/obra">← Volver</a>
            <div class="paso">PEDIR MATERIALES · <t t-esc="obra.name"/></div>
            <div class="pregunta">¿Qué necesitás?</div>
            <a class="opcion" t-foreach="materiales" t-as="m"
               t-attf-href="/app/pedir/cantidad?obra_id={{obra.id}}&amp;material_id={{m.id}}">
                <span><t t-esc="m.icono or '📦'"/> <t t-esc="m.name"/></span>
                <span style="margin-left:auto;color:var(--gris)"><t t-esc="m.detalle or ''"/></span>
            </a>
            <div class="card" t-if="not materiales">
                <h3>SIN CATÁLOGO</h3>
                <div>El administrador todavía no cargó materiales. Avisale.</div>
            </div>
        </t>
    </template>

    <!-- ============ SOCIO: PEDIR MATERIALES (paso 2) ============ -->
    <template id="pedir_paso2" name="App: pedir material paso 2">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'obra'"/>
            <a class="atras" t-attf-href="/app/pedir?obra_id={{obra.id}}">← Volver</a>
            <div class="paso">PEDIR MATERIALES</div>
            <div class="pregunta">¿Cuánto?</div>
            <div class="sub"><t t-esc="material.icono or '📦'"/> <t t-esc="material.name"/>
                <t t-if="material.detalle"> · <t t-esc="material.detalle"/></t></div>
            <form action="/app/pedir/confirmar" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="obra_id" t-att-value="obra.id"/>
                <input type="hidden" name="material_id" t-att-value="material.id"/>
                <input class="numero-grande" type="number" name="cantidad" step="any"
                       min="0.01" required="required" inputmode="decimal"
                       t-attf-placeholder="{{uom_compra_labels.get(material.uom, material.uom)}}"/>
                <input type="text" name="nota" placeholder="¿Para qué? (opcional)"
                       style="width:100%;padding:14px;border:2px solid #d7dee5;border-radius:var(--radio);font-size:16px;margin-bottom:10px"/>
                <button class="botonazo" type="submit">PEDIR ✓</button>
            </form>
        </t>
    </template>

    <!-- ============ SOCIO: PEDIDO ENVIADO ============ -->
    <template id="pedir_listo" name="App: pedido enviado">
        <t t-call="coop_portal.layout">
            <t t-set="nav_activo" t-value="'obra'"/>
            <div class="listo">
                <div class="check">🧱</div>
                <h1>Pedido enviado</h1>
                <p class="sub" style="margin-top:8px">
                    Pediste <b><t t-esc="pedido.name"/></b>.<br/>
                    Lo revisa el coordinador y si está bien va a la orden del corralón.
                </p>
                <a class="botonazo" href="/app/obra">Volver a la obra</a>
                <a class="atras" href="/app/pedir">Pedir otro</a>
            </div>
        </t>
    </template>

    <!-- ============ ASAMBLEA: SIN ASAMBLEA ABIERTA ============ -->
    <template id="asamblea_ninguna" name="App: sin asamblea">
        <t t-call="coop_portal.layout">
            <div class="listo">
                <div class="check" style="background:#a36b00">🗳️</div>
                <h1>No hay asamblea en curso</h1>
                <p class="sub" style="margin-top:8px">Cuando se abra una votación, vas a poder votar desde acá.</p>
                <a class="botonazo" href="/app">Volver al inicio</a>
            </div>
        </t>
    </template>

    <!-- ============ ASAMBLEA: PUNTOS A VOTAR ============ -->
    <template id="asamblea" name="App: asamblea en curso">
        <t t-call="coop_portal.layout">
            <a class="atras" href="/app">← Volver</a>
            <h1>🗳️ <t t-esc="asamblea.name"/></h1>
            <div class="sub">
                <t t-if="asamblea.location"><t t-esc="asamblea.location"/> · </t>
                Tu voto es secreto.
            </div>

            <div class="card" t-foreach="votos" t-as="v">
                <div style="font-weight:800;font-size:16px;margin-bottom:2px"><t t-esc="v['vote'].name"/></div>
                <div t-if="v['vote'].description" style="font-size:14px;color:var(--gris);margin-bottom:10px">
                    <t t-esc="v['vote'].description"/>
                </div>

                <t t-if="v['mi_voto']">
                    <div class="fila" style="border:0;padding:4px 0">
                        <div>Tu voto</div>
                        <span class="chip ok">✓ <t t-esc="choice_labels.get(v['mi_voto'].choice, v['mi_voto'].choice)"/></span>
                    </div>
                </t>
                <t t-elif="v['vote'].state == 'open'">
                    <a class="botonazo" style="min-height:50px;font-size:16px;margin:0"
                       t-attf-href="/app/votar?vote_id={{v['vote'].id}}">VOTAR ESTE PUNTO</a>
                </t>
                <t t-elif="v['vote'].state == 'closed'">
                    <div class="fila" style="border:0;padding:4px 0">
                        <div>Resultado</div>
                        <span t-attf-class="chip {{'ok' if v['vote'].approved else 'espera'}}">
                            <t t-esc="'Aprobada' if v['vote'].approved else 'Rechazada'"/>
                        </span>
                    </div>
                    <div style="font-size:13px;color:var(--gris)">
                        <t t-esc="v['vote'].votes_yes"/> a favor ·
                        <t t-esc="v['vote'].votes_no"/> en contra ·
                        <t t-esc="v['vote'].votes_abstain"/> abstenciones
                    </div>
                </t>
                <t t-else="">
                    <span class="chip espera">⏳ Todavía no se abrió</span>
                </t>
            </div>

            <div class="card" t-if="not votos">
                <h3>SIN PUNTOS</h3>
                <div>La asamblea está abierta pero todavía no hay votaciones cargadas.</div>
            </div>
        </t>
    </template>

    <!-- ============ ASAMBLEA: VOTAR (3 opciones) ============ -->
    <template id="votar" name="App: votar">
        <t t-call="coop_portal.layout">
            <a class="atras" href="/app/asamblea">← Volver</a>
            <div class="paso">VOTACIÓN SECRETA</div>
            <div class="pregunta"><t t-esc="vote.name"/></div>
            <div class="sub" t-if="vote.description"><t t-esc="vote.description"/></div>
            <form action="/app/votar/confirmar" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="vote_id" t-att-value="vote.id"/>
                <button class="opcion" name="choice" value="yes" type="submit"><span class="ico">👍</span> A favor</button>
                <button class="opcion" name="choice" value="no" type="submit"><span class="ico">👎</span> En contra</button>
                <button class="opcion" name="choice" value="abstain" type="submit"><span class="ico">🤷</span> Me abstengo</button>
            </form>
            <div class="card">
                <h3>ANTES DE VOTAR</h3>
                <div style="font-size:14px;color:var(--gris)">Tu voto queda registrado de forma secreta. Nadie —ni el consejo— ve qué votaste; solo se publican los totales.</div>
            </div>
        </t>
    </template>

    <!-- ============ ASAMBLEA: VOTO REGISTRADO ============ -->
    <template id="votado" name="App: voto registrado">
        <t t-call="coop_portal.layout">
            <div class="listo">
                <div class="check">🗳️</div>
                <h1>Voto registrado</h1>
                <p class="sub" style="margin-top:8px">Gracias por participar.<br/>El resultado se publica al cerrar la votación.</p>
                <a class="botonazo" href="/app/asamblea">Volver a la asamblea</a>
            </div>
        </t>
    </template>

    <!-- ============ SÍNDICO: PANEL DE CONTROL ============ -->
    <template id="sindico_control" name="App: panel del síndico">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'sindico'"/>
            <t t-set="nav_activo" t-value="'control'"/>
            <h1>🛡️ Control</h1>
            <div class="sub">Síndico · <t t-esc="member.name"/></div>

            <div class="card" style="border-left:6px solid #f5a623">
                <h3>QUÉ REVISAR</h3>
                <a class="fila" href="/app/certificados" style="text-decoration:none;color:inherit">
                    <div>✍️ Certificados esperando tu firma</div>
                    <span t-attf-class="chip {{'espera' if n_certs else 'ok'}}">
                        <t t-esc="n_certs"/> <t t-if="not n_certs">✓</t></span>
                </a>
                <a class="fila" href="/app/asamblea" style="text-decoration:none;color:inherit" t-if="asamblea">
                    <div>🗳️ Asamblea en curso</div>
                    <span class="chip espera">votar</span>
                </a>
                <div class="fila" style="border:0">
                    <div>🔴 Obras con saldo en rojo</div>
                    <span t-attf-class="chip {{'espera' if en_rojo else 'ok'}}">
                        <t t-esc="en_rojo"/> <t t-if="not en_rojo">✓</t></span>
                </div>
            </div>

            <div class="card" style="border-left:6px solid var(--verde)">
                <h3>LO QUE NO SE PUEDE TOCAR</h3>
                <div style="font-size:14px">Cada operación queda registrada con autor y hora, y nadie la puede editar ni borrar — ni el consejo.</div>
                <a class="botonazo sec" style="min-height:46px;font-size:15px;margin-top:10px" href="/app/auditoria">🔎 Abrir pista de auditoría</a>
            </div>

            <div class="card">
                <h3>TRANSPARENCIA</h3>
                <div class="fila" style="border:0;padding:0">
                    <div>Lo que ve el consejo</div><span class="chip ok">= lo que ve cada socio</span>
                </div>
                <div style="font-size:13px;color:var(--gris);margin-top:6px">Principio ACI 5. <t t-esc="n_obras"/> obras activas.</div>
            </div>
        </t>
    </template>

    <!-- ============ SÍNDICO: CERTIFICADOS A FIRMAR ============ -->
    <template id="sindico_certificados" name="App: certificados a firmar">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'sindico'"/>
            <t t-set="nav_activo" t-value="'firmar'"/>
            <h1>✍️ Certificados</h1>
            <div class="sub">Firmá desde el celular. Sin imprimir, sin escanear.</div>

            <div class="card" t-foreach="pendientes" t-as="c" style="border:2px solid var(--verde)">
                <div style="font-weight:800;font-size:16px;margin-bottom:2px">
                    N°<t t-esc="c.numero"/> · <t t-esc="c.obra_id.name"/></div>
                <div class="fila"><div>Avance acumulado</div><b><t t-esc="'%g' % c.porcentaje_avance"/>%</b></div>
                <div class="fila"><div>Monto</div><b>$ <t t-esc="'{:,.0f}'.format(c.monto_certificado).replace(',', '.')"/></b></div>
                <a class="botonazo" style="min-height:50px;font-size:16px;margin-top:8px"
                   t-attf-href="/app/firmar?cert_id={{c.id}}">✍️ REVISAR Y FIRMAR</a>
            </div>

            <div class="listo" t-if="not pendientes" style="padding:24px 10px">
                <div class="check">✓</div>
                <h1>Nada para firmar</h1>
            </div>

            <div class="card" t-if="firmados">
                <h3>YA FIRMADOS</h3>
                <div class="fila" t-foreach="firmados" t-as="f">
                    <div>N°<t t-esc="f.numero"/> · <t t-esc="f.obra_id.name"/>
                        <br/><span style="font-size:12px;color:var(--gris)">hash <t t-esc="(f.hash_firma or '')[:8]"/></span></div>
                    <span t-attf-class="chip {{'ok' if f.firma_valida else 'espera'}}">
                        <t t-if="f.firma_valida">✓ válida</t><t t-else="">⚠ alterado</t></span>
                </div>
            </div>
        </t>
    </template>

    <!-- ============ SÍNDICO: ACTO DE FIRMA ============ -->
    <template id="sindico_firmar" name="App: firmar certificado">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'sindico'"/>
            <t t-set="nav_activo" t-value="'firmar'"/>
            <a class="atras" href="/app/certificados">← Volver</a>
            <h1>Firmar Certificado N°<t t-esc="cert.numero"/></h1>
            <div class="sub"><t t-esc="cert.obra_id.name"/> · revisá antes de firmar</div>

            <div class="card">
                <h3>LO QUE VAS A FIRMAR</h3>
                <div class="fila"><div>Avance certificado</div><b><t t-esc="'%g' % cert.porcentaje_avance"/>% acumulado</b></div>
                <div class="fila"><div>Monto</div><b>$ <t t-esc="'{:,.0f}'.format(cert.monto_certificado).replace(',', '.')"/></b></div>
                <div class="fila" style="border:0"><div>Fecha de presentación</div><b><t t-esc="cert.date.strftime('%d/%m/%Y')"/></b></div>
            </div>

            <div class="card" style="background:#f0f7f3">
                <h3>QUÉ PASA AL FIRMAR</h3>
                <div style="font-size:14px;color:var(--tinta)">Queda tu firma con fecha, hora y un código único (hash) del contenido. Si después alguien cambia un número, la firma se invalida sola y se nota. El comitente lo recibe sin imprimir nada.</div>
            </div>

            <form action="/app/firmar/confirmar" method="post">
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                <input type="hidden" name="cert_id" t-att-value="cert.id"/>
                <button class="botonazo" type="submit">✍️ FIRMAR AHORA</button>
            </form>
            <a class="botonazo sec" href="/app/certificados">Todavía no — tengo dudas</a>
        </t>
    </template>

    <!-- ============ SÍNDICO: FIRMADO ============ -->
    <template id="sindico_firmado" name="App: certificado firmado">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'sindico'"/>
            <t t-set="nav_activo" t-value="'firmar'"/>
            <div class="listo">
                <div class="check">✍️</div>
                <h1>Certificado firmado</h1>
                <p class="sub" style="margin-top:8px">
                    Quedó tu firma con fecha, hora y hash <b><t t-esc="(cert.hash_firma or '')[:8]"/></b>.<br/>
                    Sin imprimir, sin escanear.
                </p>
                <a class="botonazo" href="/app/certificados">Volver a certificados</a>
            </div>
        </t>
    </template>

    <!-- ============ SÍNDICO: AUDITORÍA ============ -->
    <template id="sindico_auditoria" name="App: pista de auditoría">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'sindico'"/>
            <t t-set="nav_activo" t-value="'auditoria'"/>
            <h1>🔎 Auditoría</h1>
            <div class="sub">Todo lo que pasó. Registro inmutable.</div>

            <div class="card">
                <div class="fila" t-foreach="ops" t-as="o">
                    <div><t t-esc="o['icono']"/> <b><t t-esc="o['quien']"/></b> — <t t-esc="o['detalle']"/>
                        <br/><span style="font-size:12px;color:var(--gris)">
                            <t t-esc="o['fecha'].strftime('%d/%m')"/> · <t t-esc="o['obra']"/> · 🔒 no editable</span></div>
                </div>
                <div t-if="not ops" style="text-align:center;color:var(--gris);padding:14px">
                    Todavía no hay operaciones registradas.
                </div>
            </div>
            <div style="font-size:12px;color:var(--gris);text-align:center">Solo lectura. Nada se modifica desde acá.</div>
        </t>
    </template>

    <!-- ============ ADMIN: TABLERO MULTI-OBRA ============ -->
    <template id="admin_dashboard" name="App: tablero del administrador">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'admin'"/>
            <t t-set="nav_activo" t-value="'tablero'"/>
            <h1>📊 Administración</h1>
            <div class="sub"><t t-esc="member.name"/> · <t t-esc="len(resumenes)"/> obras activas</div>

            <a class="card" t-if="n_criticas" href="/app/admin/ruta"
               style="border-left:6px solid var(--rojo);text-decoration:none;color:inherit;display:block">
                <div class="fila" style="border:0;padding:0">
                    <div>🔴 Tareas en ruta crítica</div>
                    <span class="chip espera"><t t-esc="n_criticas"/> ver →</span>
                </div>
            </a>

            <div class="card" t-if="n_certs or n_pedidos">
                <h3>PENDIENTES EN EL EQUIPO</h3>
                <div class="fila" t-if="n_certs"><div>✍️ Certificados sin firmar</div><span class="chip espera"><t t-esc="n_certs"/></span></div>
                <div class="fila" style="border:0" t-if="n_pedidos"><div>🧱 Pedidos sin resolver (coordinador)</div><span class="chip espera"><t t-esc="n_pedidos"/></span></div>
            </div>

            <h3 style="font-size:14px;color:var(--gris);font-weight:600;margin:16px 0 8px">CARTERA DE OBRAS</h3>
            <div class="card" t-foreach="resumenes" t-as="r">
                <div class="fila" style="border:0;padding:0 0 4px">
                    <div style="font-weight:800;font-size:16px"><t t-esc="r['obra'].name"/></div>
                    <span style="font-size:13px;color:var(--gris)">Coord: <t t-esc="r['coord']"/></span>
                </div>
                <div class="barra"><div t-attf-style="width:{{min(r['avance'], 100.0)}}%"/></div>
                <div class="fila" style="border:0;padding:2px 0 0;font-size:13px">
                    <div>Avance <b><t t-esc="'%.0f' % r['avance']"/>%</b></div>
                    <t t-if="r['tiene_etapa']">
                        <div>S/planif. <b t-attf-style="color:{{'var(--rojo)' if r['saldo'] &lt; 0 else 'var(--verde)'}}">
                            $ <t t-esc="'{:,.0f}'.format(r['saldo']).replace(',', '.')"/></b></div>
                        <div>Control. <b><t t-esc="'{:,.0f}'.format(r['controlador']).replace(',', '.')"/></b></div>
                    </t>
                    <t t-else=""><div style="color:var(--gris)">sin etapa en curso</div></t>
                </div>
            </div>

            <div class="card" t-if="not resumenes">
                <h3>SIN OBRAS ACTIVAS</h3>
                <div>Cuando haya una obra activa, vas a ver su estado acá.</div>
            </div>
        </t>
    </template>

    <!-- ============ ADMIN: RUTA CRÍTICA MULTI-OBRA ============ -->
    <template id="admin_ruta" name="App: ruta crítica admin">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'admin'"/>
            <t t-set="nav_activo" t-value="'ruta'"/>
            <h1>🔴 Ruta crítica</h1>
            <div class="sub">Lo que no puede atrasarse, por obra.</div>

            <div class="card" t-foreach="data" t-as="d" style="border-left:6px solid var(--rojo)">
                <h3><t t-esc="d['obra'].name"/></h3>
                <t t-if="d['criticas']">
                    <div class="fila" t-foreach="d['criticas']" t-as="tk">
                        <div><t t-esc="tk.name"/>
                            <span t-if="tk.categoria_tarea" style="font-size:12px;color:var(--gris)"> · <t t-esc="cat_labels.get(tk.categoria_tarea, '')"/></span>
                        </div>
                        <span class="chip espera">holgura 0</span>
                    </div>
                </t>
                <div t-else="" style="font-size:14px;color:var(--gris)">
                    Sin ruta crítica calculada. Cargá tareas con duración y dependencias en el sistema y calculá la ruta desde la obra.
                </div>
            </div>
        </t>
    </template>

    <!-- ============ ADMIN: REPORTES ============ -->
    <template id="admin_reportes" name="App: reportes admin">
        <t t-call="coop_portal.layout">
            <t t-set="nav_rol" t-value="'admin'"/>
            <t t-set="nav_activo" t-value="'reportes'"/>
            <h1>📋 Reportes</h1>
            <div class="sub">Operaciones del período</div>

            <div style="display:flex;gap:8px;margin-bottom:12px">
                <a t-attf-class="botonazo {{'' if rango == 'hoy' else 'sec'}}" style="min-height:42px;font-size:14px;margin:0" href="/app/admin/reportes?rango=hoy">Hoy</a>
                <a t-attf-class="botonazo {{'' if rango == 'semana' else 'sec'}}" style="min-height:42px;font-size:14px;margin:0" href="/app/admin/reportes?rango=semana">7 días</a>
                <a t-attf-class="botonazo {{'' if rango == 'mes' else 'sec'}}" style="min-height:42px;font-size:14px;margin:0" href="/app/admin/reportes?rango=mes">Mes</a>
            </div>

            <div class="card">
                <div class="fila" style="border:0;padding:0">
                    <div><b><t t-esc="n_ops"/></b> operaciones</div>
                    <div>💸 $ <b><t t-esc="'{:,.0f}'.format(total_gasto).replace(',', '.')"/></b></div>
                    <div>📐 <b><t t-esc="'%g' % total_m2"/></b> m²</div>
                </div>
            </div>

            <div class="card">
                <div class="fila" t-foreach="ops" t-as="o">
                    <div><t t-esc="o['icono']"/> <b><t t-esc="o['quien']"/></b> — <t t-esc="o['detalle']"/>
                        <br/><span style="font-size:12px;color:var(--gris)"><t t-esc="o['fecha'].strftime('%d/%m')"/> · <t t-esc="o['obra']"/></span></div>
                </div>
                <div t-if="not ops" style="text-align:center;color:var(--gris);padding:14px">Sin operaciones en el período.</div>
            </div>
        </t>
    </template>

</odoo>
