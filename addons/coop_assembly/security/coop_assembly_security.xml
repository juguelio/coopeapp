<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_assembly_all_members_read" model="ir.rule">
            <field name="name">Todos los socios: leen asambleas</field>
            <field name="model_id" ref="model_coop_assembly"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_member'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_assembly_manager_all" model="ir.rule">
            <field name="name">Admin: gestiona asambleas</field>
            <field name="model_id" ref="model_coop_assembly"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
