<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_coop_book_export_form" model="ir.ui.view">
        <field name="name">coop.book.export.form</field>
        <field name="model">coop.book.export</field>
        <field name="arch" type="xml">
            <form string="Generar Libro Cooperativo">
                <group>
                    <field name="book_type"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button name="action_generate" type="object"
                            string="Generar PDF" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_coop_book_export" model="ir.actions.act_window">
        <field name="name">Generar Libro</field>
        <field name="res_model">coop.book.export</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
