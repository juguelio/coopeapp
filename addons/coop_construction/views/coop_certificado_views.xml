<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista formulario -->
    <record id="view_coop_certificado_form" model="ir.ui.view">
        <field name="name">coop.certificado.form</field>
        <field name="model">coop.certificado</field>
        <field name="arch" type="xml">
            <form string="Certificado de Avance">
                <header>
                    <button name="action_presentar" string="Presentar al comitente"
                            type="object" class="btn-primary"
                            invisible="state != 'borrador'"/>
                    <button name="action_aprobar" string="Aprobar"
                            type="object" class="btn-success"
                            invisible="state != 'presentado'"
                            groups="coop_members.group_coop_manager"/>
                    <button name="action_cobrar" string="Marcar como cobrado"
                            type="object" class="btn-success"
                            invisible="state != 'aprobado'"
                            groups="coop_members.group_coop_manager"/>
                    <button name="action_rechazar" string="Rechazar"
                            type="object"
                            invisible="state not in ('presentado', 'aprobado')"
                            groups="coop_members.group_coop_manager"/>
                    <button name="action_borrador" string="Volver a borrador"
                            type="object"
                            invisible="state != 'rechazado'"
                            groups="coop_members.group_coop_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="borrador,presentado,aprobado,cobrado"/>
                </header>
                <sheet>
                    <group>
                        <group string="Datos del certificado">
                            <field name="obra_id"/>
                            <field name="numero"/>
                            <field name="name"/>
                            <field name="date"/>
                        </group>
                        <group string="Montos y avance">
                            <field name="porcentaje_avance"/>
                            <field name="monto_certificado"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Observaciones">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vista lista -->
    <record id="view_coop_certificado_list" model="ir.ui.view">
        <field name="name">coop.certificado.list</field>
        <field name="model">coop.certificado</field>
        <field name="arch" type="xml">
            <list string="Certificados"
                  decoration-info="state == 'presentado'"
                  decoration-warning="state == 'aprobado'"
                  decoration-success="state == 'cobrado'"
                  decoration-danger="state == 'rechazado'">
                <field name="obra_id"/>
                <field name="numero"/>
                <field name="name"/>
                <field name="date"/>
                <field name="porcentaje_avance" string="Avance %"/>
                <field name="monto_certificado"/>
                <field name="state" widget="badge"
                       decoration-muted="state == 'borrador'"
                       decoration-info="state == 'presentado'"
                       decoration-warning="state == 'aprobado'"
                       decoration-success="state == 'cobrado'"
                       decoration-danger="state == 'rechazado'"/>
            </list>
        </field>
    </record>

    <!-- Vista búsqueda -->
    <record id="view_coop_certificado_search" model="ir.ui.view">
        <field name="name">coop.certificado.search</field>
        <field name="model">coop.certificado</field>
        <field name="arch" type="xml">
            <search string="Buscar certificados">
                <field name="obra_id" string="Obra"/>
                <field name="name" string="Descripción"/>
                <filter name="borrador" string="Borradores"
                        domain="[('state', '=', 'borrador')]"/>
                <filter name="presentados" string="Presentados"
                        domain="[('state', '=', 'presentado')]"/>
                <filter name="aprobados" string="Aprobados"
                        domain="[('state', '=', 'aprobado')]"/>
                <filter name="cobrados" string="Cobrados"
                        domain="[('state', '=', 'cobrado')]"/>
                <filter name="pendientes" string="Pendientes de cobro"
                        domain="[('state', 'in', ('presentado', 'aprobado'))]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_obra" string="Obra"
                            context="{'group_by': 'obra_id'}"/>
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Mes"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_coop_certificado" model="ir.actions.act_window">
        <field name="name">Certificados de Avance</field>
        <field name="res_model">coop.certificado</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_coop_certificado_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Registrá el primer certificado de avance de obra
            </p>
        </field>
    </record>
</odoo>
