<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- El Administrador cooperativo gestiona obras (= project.project):
             necesita acceso a Project para crear/leer obras (ej: al aprobar un
             presupuesto se crea la obra). Sin esto el manager recibía AccessError. -->
        <record id="coop_members.group_coop_manager" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>

        <!-- Socio: lee todos los avances (transparencia ACI),
             pero solo crea/edita los propios y en borrador -->
        <record id="rule_avance_medicion_member_write" model="ir.rule">
            <field name="name">Socio: solo sus avances en borrador</field>
            <field name="model_id" ref="model_coop_avance_medicion"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_member'))]"/>
            <field name="domain_force">[('member_id.partner_id.user_ids', 'in', [user.id]), ('state', '=', 'borrador')]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: sin restricciones sobre avances -->
        <record id="rule_avance_medicion_manager_all" model="ir.rule">
            <field name="name">Manager: todos los avances</field>
            <field name="model_id" ref="model_coop_avance_medicion"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Socio: crea/edita solo sus pedidos pendientes (lectura abierta) -->
        <record id="rule_pedido_member_write" model="ir.rule">
            <field name="name">Socio: solo sus pedidos pendientes</field>
            <field name="model_id" ref="model_coop_pedido_material"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_member'))]"/>
            <field name="domain_force">[('member_id.partner_id.user_ids', 'in', [user.id]), ('state', '=', 'pendiente')]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager: sin restricciones sobre pedidos -->
        <record id="rule_pedido_manager_all" model="ir.rule">
            <field name="name">Manager: todos los pedidos</field>
            <field name="model_id" ref="model_coop_pedido_material"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ===== Coordinador: opera SOLO sobre sus obras (capataz_id) ===== -->
        <!-- El manager NO hereda estas reglas restrictivas porque tiene las
             suyas (1=1) sobre los mismos modelos: las reglas de distintos
             grupos se UNEN, así el manager sigue viendo todo. -->
        <record id="rule_avance_coordinador" model="ir.rule">
            <field name="name">Coordinador: avances de sus obras</field>
            <field name="model_id" ref="model_coop_avance_medicion"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_coordinador'))]"/>
            <field name="domain_force">[('obra_id.capataz_id.partner_id.user_ids', 'in', [user.id])]</field>
        </record>
        <record id="rule_pedido_coordinador" model="ir.rule">
            <field name="name">Coordinador: pedidos de sus obras</field>
            <field name="model_id" ref="model_coop_pedido_material"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_coordinador'))]"/>
            <field name="domain_force">[('obra_id.capataz_id.partner_id.user_ids', 'in', [user.id])]</field>
        </record>

        <!-- IMPORTANTE: como el manager IMPLICA coordinador, cada modelo con
             regla de coordinador necesita una regla manager 1=1; si no, el
             manager hereda la restricción y deja de ver todo. -->
        <record id="rule_orden_corralon_coordinador" model="ir.rule">
            <field name="name">Coordinador: órdenes al corralón de sus obras</field>
            <field name="model_id" ref="model_coop_orden_corralon"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_coordinador'))]"/>
            <field name="domain_force">[('obra_id.capataz_id.partner_id.user_ids', 'in', [user.id])]</field>
        </record>
        <record id="rule_orden_corralon_manager" model="ir.rule">
            <field name="name">Manager: todas las órdenes al corralón</field>
            <field name="model_id" ref="model_coop_orden_corralon"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_orden_corralon_linea_coordinador" model="ir.rule">
            <field name="name">Coordinador: líneas de órdenes de sus obras</field>
            <field name="model_id" ref="model_coop_orden_corralon_linea"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_coordinador'))]"/>
            <field name="domain_force">[('obra_id.capataz_id.partner_id.user_ids', 'in', [user.id])]</field>
        </record>
        <record id="rule_orden_corralon_linea_manager" model="ir.rule">
            <field name="name">Manager: todas las líneas de órdenes</field>
            <field name="model_id" ref="model_coop_orden_corralon_linea"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_asignacion_coordinador" model="ir.rule">
            <field name="name">Coordinador: herramientas de sus obras</field>
            <field name="model_id" ref="model_coop_asignacion_herramienta"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_coordinador'))]"/>
            <field name="domain_force">[('obra_id.capataz_id.partner_id.user_ids', 'in', [user.id])]</field>
        </record>
        <record id="rule_asignacion_manager" model="ir.rule">
            <field name="name">Manager: todas las asignaciones de herramientas</field>
            <field name="model_id" ref="model_coop_asignacion_herramienta"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_incidente_coordinador" model="ir.rule">
            <field name="name">Coordinador: incidentes de sus obras</field>
            <field name="model_id" ref="model_coop_incidente"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_coordinador'))]"/>
            <field name="domain_force">[('obra_id.capataz_id.partner_id.user_ids', 'in', [user.id])]</field>
        </record>
        <record id="rule_incidente_manager" model="ir.rule">
            <field name="name">Manager: todos los incidentes</field>
            <field name="model_id" ref="model_coop_incidente"/>
            <field name="groups" eval="[(4, ref('coop_members.group_coop_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
